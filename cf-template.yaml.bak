                - UseSubEnvironment
                - Ref: SubEnvironment
                - Ref: Environment
              - migratedDomain
            - Fn::FindInMap:
              - EnvironmentConfiguration
              - Fn::If:
                - UseSubEnvironment
                - Ref: SubEnvironment
                - Ref: Environment
              - transitionalDomain
        - Name: SUPPORT_AUTHORIZE_CONTROLLER
          Value: 1
        - Name: ORCH_TO_AUTH_SIGNING_KEY
