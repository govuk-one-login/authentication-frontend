            - Fn::Sub: arn:aws:secretsmanager:${AWS::Region}:${AWS::AccountId}:secret:/deploy/${Environment}/frontend-cache-redis-port
        - Name: REDIS_PASSWORD
          ValueFrom:
            Fn::If:
            - UseSubEnvironment
            - Fn::Sub: arn:aws:secretsmanager:${AWS::Region}:${AWS::AccountId}:secret:/deploy/${SubEnvironment}/frontend-cache-redis-password
            - Fn::Sub: arn:aws:secretsmanager:${AWS::Region}:${AWS::AccountId}:secret:/deploy/${Environment}/frontend-cache-redis-password
        - Name: SESSION_EXPIRY
