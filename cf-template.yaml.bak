              - Fn::Sub: https://auth.${Environment}.account.gov.uk/
            - https://auth.account.gov.uk/
        - Name: ACCOUNT_MANAGEMENT_URL
          Value:
            Fn::If:
            - IsNotProduction
            - Fn::Sub: https://home.${Environment}.account.gov.uk
            - https://home.account.gov.uk
        - Name: SUPPORT_ACCOUNT_RECOVERY
          Value: 1
        - Name: BASE_URL
          Value:
            Fn::If:
            - SwitchToMigratedZone
