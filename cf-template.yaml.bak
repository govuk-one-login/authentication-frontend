      orchStubToAuthSigningPublicKey: '-----BEGIN PUBLIC KEY-----

        MFkwEwYHKoZIzj0CAQYIKoZIzj0DAQcDQgAEwe8ey1GnTbH6E69EJFUkt4WQc1Kl

