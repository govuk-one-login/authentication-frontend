            - Fn::FindInMap:
              - EnvironmentConfiguration
              - Ref: Environment
              - orchToAuthSigningPublicKey
        - Name: ORCH_TO_AUTH_CLIENT_ID
          Value: orchestrationAuth
        - Name: ORCH_TO_AUTH_AUDIENCE
