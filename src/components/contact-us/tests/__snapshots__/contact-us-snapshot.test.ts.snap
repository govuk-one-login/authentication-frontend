exports[`Snapshot:: contact us - public user signing_in should render /contact-us-questions?theme=signing_in&subtheme=technical_error 1`] = `
"<!DOCTYPE html>
<html lang=\\"en\\" class=\\"govuk-template\\">
  <head>
    <meta charset=\\"utf-8\\">
    <title>


        There was a technical problem
        -

    GOV.UK One Login
</title>
