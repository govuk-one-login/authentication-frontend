            <a href=\\"/contact-us-further-information?theme=signing_in\\" class=\\"govuk-back-link\\">Back</a>


        <main class=\\"govuk-main-wrapper \\" id=\\"main-content\\"
              role=\\"main\\">
            <div class=\\"govuk-grid-row\\">
                <div class=\\"govuk-grid-column-two-thirds \\">




















        <h1 class=\\"govuk-heading-l govuk-!-margin-top-0 govuk-!-margin-bottom-3\\">
    You’ve lost access to the way you get a security code
</h1>

<form action=\\"/contact-us-questions?radio_buttons=true\\" method=\\"post\\" novalidate>

<input type=\\"hidden\\" name=\\"_csrf\\" value=\\"TEST_CSRF_TOKEN\\"/>
<input type=\\"hidden\\" name=\\"theme\\" value=\\"signing_in\\"/>
<input type=\\"hidden\\" name=\\"subtheme\\" value=\\"lost_security_code_access\\"/>
<input type=\\"hidden\\" name=\\"backurl\\" value=\\"/contact-us-further-information?theme=signing_in\\"/>
<input type=\\"hidden\\" name=\\"fromURL\\" value=\\"\\"/>
<input type=\\"hidden\\" name=\\"formType\\" value=\\"noPhoneNumberAccess\\"/>
<input type=\\"hidden\\" name=\\"referer\\" value=\\"\\"/>


















<div class=\\"govuk-form-group\\">

  <fieldset class=\\"govuk-fieldset\\">

    <legend class=\\"govuk-fieldset__legend govuk-fieldset__legend--m\\">

      How do you get security codes to sign in?

    </legend>


    <div class=\\"govuk-radios\\" data-module=\\"govuk-radios\\">







      <div class=\\"govuk-radios__item\\">
        <input class=\\"govuk-radios__input\\" id=\\"securityCodeSentMethod\\" name=\\"securityCodeSentMethod\\" type=\\"radio\\" value=\\"text_message_uk_number\\">
        <label class=\\"govuk-label govuk-radios__label\\" for=\\"securityCodeSentMethod\\">
          Text message to a UK phone number
        </label>

      </div>








      <div class=\\"govuk-radios__item\\">
        <input class=\\"govuk-radios__input\\" id=\\"securityCodeSentMethod-2\\" name=\\"securityCodeSentMethod\\" type=\\"radio\\" value=\\"text_message_international_number\\" data-aria-controls=\\"conditional-securityCodeSentMethod-2\\">
        <label class=\\"govuk-label govuk-radios__label\\" for=\\"securityCodeSentMethod-2\\">
          Text message to a phone number from another country
        </label>

      </div>

      <div class=\\"govuk-radios__conditional govuk-radios__conditional--hidden\\" id=\\"conditional-securityCodeSentMethod-2\\">
        <div class=\\"govuk-form-group\\">
    <label class=\\"govuk-label\\" for=\\"country\\">
      Which country?
    </label>



    <div id=\\"country-hint\\" class=\\"govuk-hint\\">
      Do not enter your phone number
    </div>


    <input

























     class=\\"govuk-input govuk-!-width-two-thirds\\" id=\\"country\\" name=\\"country\\" type=\\"text\\" spellcheck=\\"false\\" aria-describedby=\\"country-hint\\">

  </div>
      </div>








      <div class=\\"govuk-radios__item\\">
        <input class=\\"govuk-radios__input\\" id=\\"securityCodeSentMethod-3\\" name=\\"securityCodeSentMethod\\" type=\\"radio\\" value=\\"authenticator_app\\">
        <label class=\\"govuk-label govuk-radios__label\\" for=\\"securityCodeSentMethod-3\\">
          Authenticator app
        </label>

      </div>




    </div>

  </fieldset>

</div>







<div class=\\"govuk-form-group govuk-character-count\\"









   data-module=\\"govuk-character-count\\" data-maxlength=\\"1200\\" data-i18n.characters-under-limit.other=\\"You have %{count} characters remaining\\" data-i18n.characters-under-limit.one=\\"One character to go\\"
   data-i18n.characters-at-limit=\\"You have %{count} characters remaining\\" data-i18n.characters-over-limit.other=\\"You have %{count} characters too many\\" data-i18n.characters-over-limit.one=\\"One character too many\\"
  >
  <label class=\\"govuk-label govuk-label--s\\" for=\\"optionalDescription\\">
