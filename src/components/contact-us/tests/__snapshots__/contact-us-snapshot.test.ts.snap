exports[`Snapshot:: contact us - public user signing_in should render /contact-us-questions?theme=signing_in&subtheme=lost_security_code_access 1`] = `
"<!DOCTYPE html>
<html lang=\\"en\\" class=\\"govuk-template\\">
  <head>
    <meta charset=\\"utf-8\\">
    <title>


        You’ve lost access to the way you get a security code
        -

    GOV.UK One Login
</title>
    <meta name=\\"viewport\\" content=\\"width=device-width, initial-scale=1, viewport-fit=cover\\">
