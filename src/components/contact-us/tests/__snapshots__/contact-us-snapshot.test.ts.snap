            <div class=\\"govuk-grid-row\\">
                <div class=\\"govuk-grid-column-two-thirds \\">




















































        <h1 class=\\"govuk-heading-l govuk-!-margin-top-0 govuk-!-margin-bottom-3\\">
  You had a problem signing in to the GOV.UK One Login app
</h1>

<form action=\\"/contact-us-questions\\" method=\\"post\\" novalidate>

<input type=\\"hidden\\" name=\\"_csrf\\" value=\\"TEST_CSRF_TOKEN\\"/>
<input type=\\"hidden\\" name=\\"theme\\" value=\\"id_check_app\\"/>
<input type=\\"hidden\\" name=\\"subtheme\\" value=\\"one_login_app_sign_in_problem\\"/>
<input type=\\"hidden\\" name=\\"backurl\\" value=\\"/contact-us-further-information?theme=id_check_app\\"/>
<input type=\\"hidden\\" name=\\"fromURL\\" value=\\"\\"/>
<input type=\\"hidden\\" name=\\"formType\\" value=\\"oneLoginAppSignInProblem\\"/>
<input type=\\"hidden\\" name=\\"referer\\" value=\\"\\"/>








<div class=\\"govuk-form-group govuk-character-count\\"









   data-module=\\"govuk-character-count\\" data-maxlength=\\"1200\\" data-i18n.characters-under-limit.other=\\"You have %{count} characters remaining\\" data-i18n.characters-under-limit.one=\\"One character to go\\"
   data-i18n.characters-at-limit=\\"You have %{count} characters remaining\\" data-i18n.characters-over-limit.other=\\"You have %{count} characters too many\\" data-i18n.characters-over-limit.one=\\"One character too many\\"
  >
  <label class=\\"govuk-label govuk-label--s\\" for=\\"issueDescription\\">
    What happened?
  </label>



  <div id=\\"issueDescription-hint\\" class=\\"govuk-hint\\">
    For example, did you see any warning or error messages?
  </div>



  <textarea class=\\"govuk-textarea govuk-js-character-count\\" id=\\"issueDescription\\" name=\\"issueDescription\\" rows=\\"5\\" aria-describedby=\\"issueDescription-info issueDescription-hint\\"></textarea>

  <div id=\\"issueDescription-info\\" class=\\"govuk-hint govuk-character-count__message\\">
    You can enter up to 1200 characters
  </div>

</div>






<div class=\\"govuk-form-group\\">
  <label class=\\"govuk-label govuk-label--s\\" for=\\"serviceTryingToUse\\">
    What service were you trying to use?
  </label>



  <div id=\\"serviceTryingToUse-hint\\" class=\\"govuk-hint\\">
    If you cannot remember the name of the service, tell us what you were trying to do, for example get a DBS check. Or you can tell us the name of the government department you’ve been dealing with.
  </div>


  <input

























   class=\\"govuk-input\\" id=\\"serviceTryingToUse\\" name=\\"serviceTryingToUse\\" type=\\"text\\" spellcheck=\\"false\\" aria-describedby=\\"serviceTryingToUse-hint\\">

</div>



<div class=\\"govuk-warning-text\\">
  <span class=\\"govuk-warning-text__icon\\" aria-hidden=\\"true\\">!</span>
  <strong class=\\"govuk-warning-text__text\\">
    <span class=\\"govuk-visually-hidden\\">Warning</span>
    Do not include personal or financial information, for example your passport or credit card details.
  </strong>
</div>






<div class=\\"govuk-form-group\\">

  <fieldset class=\\"govuk-fieldset\\">

    <legend class=\\"govuk-fieldset__legend govuk-fieldset__legend--m\\">

      Can we reply to you by email?

    </legend>


    <div class=\\"govuk-radios\\" data-module=\\"govuk-radios\\">







      <div class=\\"govuk-radios__item\\">
        <input class=\\"govuk-radios__input\\" id=\\"contact\\" name=\\"contact\\" type=\\"radio\\" value=\\"true\\" data-aria-controls=\\"conditional-contact\\">
        <label class=\\"govuk-label govuk-radios__label\\" for=\\"contact\\">
          Yes
        </label>

      </div>

      <div class=\\"govuk-radios__conditional govuk-radios__conditional--hidden\\" id=\\"conditional-contact\\">
        <div class=\\"govuk-form-group\\">
    <label class=\\"govuk-label\\" for=\\"email\\">
      Email address
    </label>



    <div id=\\"email-hint\\" class=\\"govuk-hint\\">
      We will only use this to reply to your message
    </div>


    <input



























     class=\\"govuk-input govuk-!-width-two-thirds\\" id=\\"email\\" name=\\"email\\" type=\\"email\\" spellcheck=\\"false\\" aria-describedby=\\"email-hint\\" autocomplete=\\"email\\">

  </div>






  <div class=\\"govuk-form-group\\">
    <label class=\\"govuk-label\\" for=\\"name\\">
      Name (Optional)
    </label>


    <input























     class=\\"govuk-input govuk-!-width-two-thirds\\" id=\\"name\\" name=\\"name\\" type=\\"text\\" spellcheck=\\"false\\">

  </div>

  <br />
  <p class=\\"govuk-body\\">Read our <a href=\\"/govuk-one-login-privacy-notice\\" class=\\"govuk-link\\" rel=\\"noreferrer noopener\\" target=\\"_blank\\">privacy notice</a> for more information on how we use your personal information.</p>
      </div>








