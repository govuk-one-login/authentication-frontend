<h1 class="govuk-heading-l govuk-!-margin-top-0 govuk-!-margin-bottom-3">
  {{ 'pages.contactUsQuestions.signingInProblemWithAPasskey.header' | translate }}
</h1>

<form action="{{formSubmissionUrl}}?radio_buttons=true" method="post" novalidate>

  <input type="hidden" name="_csrf" value="{{csrfToken}}"/>
  <input type="hidden" name="theme" value="{{theme}}"/>
  <input type="hidden" name="subtheme" value="{{subtheme}}"/>
  <input type="hidden" name="backurl" value="{{backurl}}"/>
  <input type="hidden" name="fromURL" value="{{fromURL}}"/>
  <input type="hidden" name="formType" value="signingInProblemWithAPasskey"/>
  <input type="hidden" name="referer" value="{{referer}}"/>
  {% include 'contact-us/questions/_id-check-app-hidden-fields.njk' %}

  <p class="govuk-body">{{ 'pages.contactUsQuestions.signingInProblemWithAPasskey.description' | translate }}</p>

  {{ govukRadios({
    name: "whatWereYouTryingToDo",
    fieldset: {
      legend: {
        text: 'pages.contactUsQuestions.signingInProblemWithAPasskey.section1.header' | translate,
        isPageHeading: false,
        classes: "govuk-fieldset__legend--m"
      }
    },
    items: [
      {
        value: "set_up_a_new_passkey",
        checked: whatWereYouTryingToDo === 'set_up_a_new_passkey',
        text: 'pages.contactUsQuestions.signingInProblemWithAPasskey.section1.options.set_up_a_new_passkey' | translate
      },
      {
        value: "sign_in_using_your_passkey",
        checked: whatWereYouTryingToDo === 'sign_in_using_your_passkey',
        text: 'pages.contactUsQuestions.signingInProblemWithAPasskey.section1.options.sign_in_using_your_passkey' | translate
      },
      {
        value: "something_else",
        checked: whatWereYouTryingToDo === 'something_else',
        text: 'pages.contactUsQuestions.signingInProblemWithAPasskey.section1.options.something_else' | translate
      }
    ],
    errorMessage: {
      text: errors['whatWereYouTryingToDo'].text
    } if (errors['whatWereYouTryingToDo'])
  }) }}

  {% include 'contact-us/questions/_what-happened.njk' %}

  {% include "contact-us/questions/_service-trying-to-use.njk" %}

  {{ govukWarningText({
    text:'pages.contactUsQuestions.personalInformation.paragraph1' | translate,
    iconFallbackText: "Warning"
  }) }}

  {% include 'contact-us/questions/_reply_by_email.njk' %}

  {{ govukButton({
    "text": "general.sendMessage" | translate,
    "type": "Submit",
    "preventDoubleClick": true
  }) }}

</form>
